{
  "manifest_version": 2,
  "name": "Workspaces",
  "version": "1.0.14",
  "description": "Edge-like workspaces for Firefox with automatic cross-device sync.",
  "author": "Firefox Workspaces",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "activeTab",
    "theme",
    "alarms",
    "sessions",
    "identity",
    "https://*.firebaseio.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg",
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    },
    "default_title": "Workspaces"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-workspaces@extension",
      "strict_min_version": "89.0"
    }
  }
}
